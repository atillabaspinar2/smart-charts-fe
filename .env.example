# Required for production builds: base URL of the NestJS backend (no trailing slash).
# Vite bakes this in at build time — set it in your host’s build env (Vercel/Netlify/etc.).
# If unset on a public site, MCP/auth requests will fail (browsers block public → localhost).
VITE_API_URL=https://your-backend.example.com

# Assistant LLM uses a Gemini API key entered in the app, not env.
